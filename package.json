{
  "name": "groupus-desktop-client",
  "private": true,
  "version": "1.1.2",
  "description": "Unofficial cross-platform GroupUs desktop client for GroupMe, built with Electron and React.",
  "author": {
    "name": "Kevin Pulikkottil",
    "email": "kpulik@users.noreply.github.com"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "electron:compile:preload": "esbuild electron/preload.ts --bundle --platform=node --outfile=dist-electron/preload.js --format=cjs --external:electron",
    "electron:compile": "tsc -p tsconfig.electron.json && npm run electron:compile:preload",
    "electron:dev": "npm run electron:compile && concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"npm run electron:compile:preload\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:dev:tools": "npm run electron:compile && concurrently \"vite\" \"tsc -p tsconfig.electron.json --watch\" \"npm run electron:compile:preload\" \"wait-on http://localhost:5173 && ELECTRON_OPEN_DEVTOOLS=1 VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && npm run electron:compile:preload && electron-builder"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.groupus.desktop",
    "productName": "GroupUs",
    "artifactName": "GroupUs-${version}-${os}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "kpulik",
        "repo": "GroupUs"
      }
    ],
    "mac": {
      "icon": "build/icons/icon.icns",
      "category": "public.app-category.social-networking",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icons/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "build/icons/icon.ico",
      "uninstallerIcon": "build/icons/icon.ico",
      "installerHeaderIcon": "build/icons/icon.ico"
    },
    "linux": {
      "icon": "build/icons/linux",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release"
    }
  }
}
